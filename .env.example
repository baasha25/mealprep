# Copy to .env and fill in. NEVER commit real secrets.

# Postgres connection string (local, Neon, or Supabase)
DATABASE_URL="postgresql://user@localhost:5432/prepflow_dev?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk auth — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Stripe (test mode; Connect for platform payments)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# Email — Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM=""

# Background jobs — Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Invoice scanning (Pro feature) — Claude vision reads supplier invoices
ANTHROPIC_API_KEY=""

# Scheduled notifications — shared secret the cron must send to /api/cron/notifications
CRON_SECRET=""
